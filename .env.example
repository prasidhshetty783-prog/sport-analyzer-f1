# --- OpenF1 (real-time access only; historical data needs NO token) ---
# Paid account token. App must degrade gracefully without it (replay mode only).
# When set, a "● LIVE SESSION" entry appears in the race picker (Phase 5).
OPENF1_TOKEN=

# Live transport: "rest" (default, REST polling) or "mqtt" (stub — not yet built).
OPENF1_TRANSPORT=rest

# --- Kaggle (for ML training datasets, Phase 3) ---
# From kaggle.com -> Account -> Create New API Token
KAGGLE_USERNAME=
KAGGLE_KEY=
